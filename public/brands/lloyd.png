<!-- Floating launcher + iframe panel -->
<div id="havells-chatbot" class="havells-chatbot bottom-right"
     style="--chatbot-width:380px; --chatbot-height:560px;">
   
	
	
	
<button
  id="havells-chatbot-toggle"
  class="havells-chatbot__toggle"
  aria-expanded="false"
  
>
<div class="havells-chatbot__icon">&nbsp;</div>
<span class="havells-chatbot__text">Havells.AI</span>
</button>



    <div class="havells-chatbot__iframe-wrap" hidden>
        <iframe
            src="https://aichat.havells.com/chat?userId=&amp;userName=&amp;authToken="
            title="Havells&#x20;AI&#x20;Chat"
            class="havells-chatbot__iframe"
            allow="clipboard-read; clipboard-write; microphone; camera"
            loading="lazy"
        ></iframe>
    </div>
</div>

<link rel="stylesheet" type="text/css"
      href="https://havells.com/static/version1772522340/frontend/Custom/default/en_US/Havells_Chatbot/css/chatbot.min.css" />



<script>
require(['jquery'], function ($) {
  $(function () {
    var $toggle = $('#havells-chatbot-toggle');
    var $wrap   = $('.havells-chatbot__iframe-wrap');

    function openPanel() {
      $toggle.attr('aria-expanded', 'true');
      $wrap.removeAttr('hidden');
      // Optionally focus the close button if you have one
      // $wrap.find('.close').focus();
    }

    function closePanel() {
      $toggle.attr('aria-expanded', 'false');
      $wrap.attr('hidden', true);
      $toggle.focus();
    }

    // Toggle button
    $toggle.on('click', function () {
      var expanded = $toggle.attr('aria-expanded') === 'true';
      expanded ? closePanel() : openPanel();
    });

    // Listen for close requests from iframe
    window.addEventListener('message', function (event) {
      // SECURITY: validate origin if you know the iframe’s origin
      // if (event.origin !== 'https://chat.havells.com') return;

      let data = event.data;
      if (typeof data === 'string') {
        try { data = JSON.parse(data); } catch (e) {}
      }

      if ((data && data.type === 'close') || data === 'close') {
        closePanel();
      }
    }, false);

    // Optional: expose a global for manual testing
    window.havellsCloseChat = closePanel;
  });
});
</script>





<script>    require(['magentoStorefrontEvents'], function (magentoStorefrontEvents) {
