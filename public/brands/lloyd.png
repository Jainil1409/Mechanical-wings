						var swatchOptions = $productItem.find('.swatch-option.color');
						var attributeId = '';
						var attributeName = '';
						var attributeType = '';
						if (swatchOptions.length > 0) {
							var selectedSwatchOption = swatchOptions.filter('.selected');
							if (selectedSwatchOption.length > 0) {
								attributeId = selectedSwatchOption.data('option-id');
								attributeName = selectedSwatchOption.data('option-label');
								var swatchAttribute = selectedSwatchOption.closest('.swatch-attribute');
								if (swatchAttribute.length > 0) {
									attributeType = swatchAttribute.data('attribute-code');
								}		
							}
						}
						
						var onCategoryProductClick = {
							categoryName: categoryName,
							categoryId: categoryId,
							productName: productName,
							productId: productId,
							pageName: 'Category Page',
							pageUrl: window.location.protocol + "//" + window.location.host + window.location.pathname,
							source: 'Havells Website'
						}
						
						if (attributeId) {
