				function corporateEvents(pageName, eventName) {
					var corporateVars = {
						mobileNumber: '',
						loginStatus: 'guest',
						pageName: pageName,
						pageUrl: window.location.protocol + "//" + window.location.host + window.location.pathname,
						language: 'en_US',
						utmSource: '',
						utmMedium: '',
						utmCampaign: ''
					}
					if (typeof Moengage !== 'undefined' && Moengage.track_event) {
						Moengage && Moengage.track_event(eventName, corporateVars);
					}
				}
				
