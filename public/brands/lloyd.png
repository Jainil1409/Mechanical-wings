                // for cart page
                if ($('body').hasClass("checkout-cart-index")){
                    let product = [];
                    function getProduct(){
                        product = [];
                        $('.card-cart').each(function (index,element) {
                            let temp = {
                                "productID":$(element).find('.sku-name').text().replace("SKU: ",""),
                                "tags":"",
                                "quantity":$(element).find('.card-cart-qty input').val()
                            }
                            product.push(temp);
                        })
                    }
                    getProduct();
                    console.log(product);
                    function updateCartAction(){
                        console.log("update action called");
                        $('[class*="card-cart-qty"],[class*="card-cart-trash"]').off('click');
                        $('[class*="card-cart-trash"],[class*="remove-cart"]').off('click');
                        //$('button[name="update_cart_action"]').off('click'); // it remove clear shopping cart event
                        $('.cart.table-wrapper').off('click');

                        $('.cart.table-wrapper').on('click','button[name="update_cart_action"]',function() {
                            let text = $(this).hasClass('btn-minus')?"product quantity reduced on cart page":"product quantity increased on cart page";
                            let sku = $(this).parent().find('.input-text.qty').attr('data-cart-item-id');
                            setTimeout(()=>{
                                window.havellsDataLayer.push({
                                    "event": "cartAction",
                                    "product":[{
                                        "productID":sku
                                    }],
                                    "link": {
                                        "linkName": text,
                                        "linkType": "cart"
                                    }
                                });
                            },3000)
                        });
                        $('[class*="card-cart-trash"],[class*="remove-cart"]').on('click','.action.action-delete,a',function(){
                          //  $(this).one('click', function() {
                            var ref= $(this).parent();
                            let text = "product removed using x from cart page";
                            if(ref.hasClass('card-cart-trash')){
                                text = "product removed from cart page"
                            }
                            let sku = $(this).parent().parent().find('.input-text.qty').attr('data-cart-item-id');
                                window.havellsDataLayer.push({
                                    "event": "scRemove",
                                    "product":[{
                                        "productID":sku
                                    }] ,
                                    "link": {
                                        "linkName": text,
                                        "linkType": "cart"
                                    }
                                });
                        //}).trigger('click');
                    });
                    }

                    $(document).ajaxComplete(function () {
                        updateCartAction();
                    });
                    $('.cart.main.actions').on('click','#empty_cart_button',function(){
                        getProduct();

                        $('aside.modal-popup.confirm._show').on('click',"button.action-secondary.action-dismiss,button.action-primary.action-accept",function(){
                            window.havellsDataLayer.push({
                                "event": "scRemove",
                                "product": product,
                                "link": {
                                    "linkName": "clear shopping cart on cart page",
                                    "linkType": "cart"
                                }
                            });
                        })
                    });
	
                    $('.cart-summary-sidebar.sticky-sidebar').on('click','button.action.primary.checkout',function(e){
                        // not working
                        e.preventDefault();
                        getProduct();
                        window.havellsDataLayer.push({
                            "event":"checkout",
                            "product":product,
                            "link":{
                                "linkName":"checkout from cart page",
                                "linkType":"cart"
                            }
                        });
                        gtag('event', 'conversion', {'send_to': 'AW-740614232/7rNaCKWMxPUZENjAk-EC'});
                    });
                    window.havellsDataLayer.push({
                        "event": "cartLoad",
                        "page": {
                            "pageName": "checkout:cart",
                            "channel": "checkout",
                            "siteSection1": "checkout",
                            "siteSection2": "cart",
                            "siteSection3": "",
                            "pageType": 'checkout',
                            "siteType": siteType.toLowerCase(),
                            "brand": brand
                        },
                        "user": {
                            "userID": '',
                            "userType": '',// could be employee, customer, business
                            "loginStatus": 'anonymous'
                        },
                        "product": product
                    });
                    updateCartAction();
                }

