<script type="text/javascript">
  require(['Magento_Customer/js/customer-data'], function(customerData) {
    'use strict';
    try {
      function loadBreezeSDK() {
        const alreadyLoaded = document.getElementById("breeze-sdk-loader");
        if (alreadyLoaded === null) {
          const breezeSDKHost = "https://sdk.breeze.in/electron/latest/index.js";
          const scriptTag = document.createElement("script");
          scriptTag.setAttribute("src", breezeSDKHost);
          scriptTag.setAttribute("type", "module");
          scriptTag.setAttribute("id", "breeze-script-tag");
          scriptTag.setAttribute("data-environment", "production");
          scriptTag.setAttribute("data-platform", "magento");
          scriptTag.setAttribute("data-enable-external-trackers", "true");
          scriptTag.setAttribute("data-emit-tracker-events", "true");
          scriptTag.setAttribute("data-enable-snap-tracker", "false");
          scriptTag.setAttribute("data-enable-ga", "true");
          scriptTag.setAttribute("data-enable-fbp", "true");
          scriptTag.setAttribute("data-ga-version", "new");
          scriptTag.setAttribute("data-merchantid", "havells");
          scriptTag.setAttribute("data-journey", "dpay");
          scriptTag.async = true;
          document.head.append(scriptTag);
        }
      };
      customerData.reload(['cart'], true);
      loadBreezeSDK();
    } catch (e) {
      console.error("Error in running the script", e);
    }
  });
</script>
