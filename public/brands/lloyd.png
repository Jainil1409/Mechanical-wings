    <div aria-atomic="true" role="alert" class="messages">
        <!-- Error messages will be dynamically inserted here -->
    </div>
</div>
<style>
    .custom-message-error {
    color: #f00;
    background-color: #fdd;
    border: 1px solid #f00;
    padding: 10px;
    margin: 10px 0;
    position: relative;
    padding-right: 30px; /* Space for close button */
}

.custom-message-success {
    color: #4caf50;
    background-color: #e8f5e9;
    border: 1px solid #4caf50;
    padding: 10px;
    margin: 10px 0;
    position: relative;
    padding-right: 30px; /* Space for close button */
}

.custom-message-error .close-btn, .custom-message-success .close-btn {
    position: absolute;
    top: 5px;
    right: 5px;
    background: none;
    border: none;
    font-size: 16px;
    cursor: pointer;
    color: #fff; /* White color for close icon */
}

.custom-message-error .close-btn:before, .custom-message-success .close-btn:before {
    content: '✖'; /* Unicode for cross symbol */
    color: #fff; /* White color for cross symbol */
    font-size: 18px; /* Increase icon size if needed */
}

.custom-message-error .close-btn:hover, .custom-message-success .close-btn:hover {
    color: #f00; /* Red color when hovered for error messages */
}

.custom-message-success .close-btn:hover {
    color: #4caf50; /* Green color when hovered for success messages */
}

</style>


