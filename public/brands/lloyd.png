				//On click of minicart checkout button moengage event
				$('#minicart-content-wrapper').on('click','button#top-cart-btn-checkout',function() {
					var productNames = [];
					var productSkus = [];
					var productQtys = [];
					var productPrices = [];
	
					$('#mini-cart li[data-role="product-item"]').each(function() {
						var $item = $(this);
						var productName = $item.find('.product-item-name a').text().trim();
						var sku = $item.find('input[data-cart-item-id]').data('cart-item-id');
						var qty = $item.find('input[data-item-qty]').val();
						var productPrice = $item.find('.minicart-price .price').text();							
						var productPrice = parseFloat(productPrice.trim().replace(/\s+/g, '').replace('₹', '').replace(/,/g, ''));
						
						productNames.push(productName);
						productSkus.push(sku);
						productQtys.push(qty);
						productPrices.push(productPrice);

					});
					var subtotal = $('div.subtotal span.price').text().trim();						
					cartPageMoengage.checkoutMiniCartClick(productNames,productSkus,productQtys,productPrices,subtotal);
				});
				
			}); 
		//}
	});
</script>
	<script type="text/javascript">
