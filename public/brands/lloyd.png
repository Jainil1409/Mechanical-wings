<script type="text/javascript">
	require([
		'jquery',
		'jquery/ui'
	], function ($) {
		$(document).ready(function () {
			var utmSource = '';
			var admitadUid = '';
			
			var expiryDate = new Date();
			expiryDate.setDate(expiryDate.getDate() + 30);
			
			if (utmSource === 'admitad' && admitadUid) {

				document.cookie = "dealer_code=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";

				document.cookie = "admitad_uid=" + (admitadUid || '') + "; expires=" + expiryDate.toUTCString() + "; path=/";
				document.cookie = "utm_source=admitad; expires=" + expiryDate.toUTCString() + "; path=/";
			} else {
				const urlParams = new URLSearchParams(window.location.search);				
				
				var utmSourceVal = urlParams.get('utm_source');
				var admitadUidVal = urlParams.get('admitad_uid');
				const hasUtmSource = urlParams.has('utm_source');
				const hasAdmitadUid = urlParams.has('admitad_uid');
				
				if (hasUtmSource && hasAdmitadUid && utmSourceVal === 'admitad' && admitadUidVal) {
					document.cookie = "dealer_code=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
					document.cookie = "admitad_uid=" + admitadUidVal + "; expires=" + expiryDate.toUTCString() + "; path=/";
					document.cookie = "utm_source=admitad; expires=" + expiryDate.toUTCString() + "; path=/";
					return;
				}

				if (hasUtmSource && utmSourceVal !== 'admitad') {
					document.cookie = "utm_source=" + (utmSource || '') + "; expires=" + expiryDate.toUTCString() + "; path=/";
					return;
				}
			}
		});
	});
</script>

<script>

    require(['jquery','Magento_Customer/js/customer-data','jquery/ui'], function ($,customerData) {
        $(document).ready(function () {
            let currentURL = window.location.href;
            let siteType = (currentURL.includes("business") || currentURL.includes("corporate"))?"business":"consumer";
            let brand = "";
            let brands = ['lloyd','havells_studio','crabtree','reo','default'];
                brands.forEach((element)=>{
                    if($('body').hasClass(element)){
                        brand = (element=="default")?"":element;
                    }
                });
            if ($('body').hasClass("cms-home")) {
                //console.log("home page");
                window.havellsDataLayer.push({
                    "event": "pageLoad",
                    "page": {
                        "pageName": 'home page',
                        "channel": 'home',
                        "siteSection1": 'home',
                        "siteSection2": '',
                        "siteSection3": '',
                        "pageType": 'home',
                        "siteType": siteType,
                        "brand": brand
                    },
                    "user": {
                        "userID": '',
                        "userType": '',// could be employee, customer, business
                        "loginStatus": 'anonymous'
                    }
                });
            }

        //     Category Page catalog-category-view
            //
            var siteSection=[];
            var classes = [];
            //   if(!$('body').hasClass("checkout-cart-index") && !$('body').hasClass("customer-account-login") && !$('body').hasClass("checkout-index-index") && !$('body').hasClass('cms-home') && !$('body').hasClass('mpblog-post-index') && !$('body').hasClass('cms-business-home')) {
            if($('body').hasClass("cms-page-view") || $('body').hasClass("page-products") || $('body').hasClass('catalog-product-view') || $('body').hasClass('mpblog-post-view')) {
                var count= 0 ;
                var checkExist = setInterval(function () {
                    let breadcrumbs = $('.breadcrumbs ul.items li');
                    count++;
                    if(count==20){
                        clearInterval(checkExist);
                    }
                    if (breadcrumbs.length) {
                        clearInterval(checkExist);
                        breadcrumbs.each(function (index, element) {
                            let ref = $(this);
                            let elem = ref.html();
                            // console.log(index);
                            // console.log(breadcrumbs.length);
                            // console.log(elem);
                            let category = "", text = "";
                            if (index != 0) {
                                if (index < breadcrumbs.length - 1) {
                                    text = ref.find('a').html();

                                } else {
                                    text = ref.html();
                                }
                                category = text.replace("<strong>", "");
                                category = category.replace("</strong>", "");
                                siteSection.push(category.trim().toLowerCase());
                            }
                        })
                    }
                    //console.log(siteSection);
                }, 50);
            }
            //console.log(siteSection);
            setTimeout(function () {
                if ($('body').hasClass("catalog-category-view") || $('body').hasClass("products-new-index") || $('body').hasClass("products-bestseller-index")) {
                    //console.log("Category  page");
                    let siteSection0 = (typeof siteSection[0]!="undefined")?siteSection[0].toLowerCase():"";
                    let siteSection1 = (typeof siteSection[1]!="undefined")?siteSection[1].toLowerCase():"";
                    let siteSection2 =(typeof siteSection[2]!="undefined")?siteSection[2].toLowerCase():"";
                    let pageName = siteSection0
                    if(siteSection1!=""){
                        pageName+= ":"+siteSection1
                    }
                    if(siteSection2!=""){
                        pageName+= ":"+siteSection2
                    }
                    var getSelector = $('.cat-slider').length;
                    let pageType = "category page";
                    if(getSelector<=0){
                        pageType = "listing page";
                    }
                    window.havellsDataLayer.push({
                        "event": "pageLoad",
                        "page": {
                            "pageName": pageName.toLowerCase(),
                            "channel": siteSection0,
                            "siteSection1": siteSection0,
                            "siteSection2": siteSection1,
                            "siteSection3": siteSection2,
                            "pageType": pageType,
                            "siteType": siteType.toLowerCase(),
                            "brand": brand
                        },
                        "user": {
                            "userID": '',
                            "userType": '',// could be employee, customer, business
                            "loginStatus": 'anonymous'
                        }
                    });
                    // View Details
                    $('.product-item-info').on('click','a.product-item-link,a.product-item-photo',function () {
                        var ref = $(this);
                        var name = $(this).closest('li').find('.product-item-name a').text().trim();
                        var sku = $(this).closest('li').find('form').attr('data-product-sku');
                        if(ref.hasClass('btn')){
                            name = "view details";
                        }else if(ref.hasClass('product-item-photo')){
                            name = ref.find('img').attr('src');
                        }
                        window.havellsDataLayer.push({
                            "event":"productClicked",
                            "link":{
                                "linkName":name,
                                "linkType": "product clicked"
                            },
                            "product":{
                                "productID":sku,
                                "tags":"",
                            }
                        });
                    });

                    $('.category-view-item').on('click','a',function(){
                        let category = $('.breadcrumbs ul.items li:last').text().trim();
                        var text = $(this).find('.catg-title').html().trim();
                        window.havellsDataLayer.push({
                            "event":"sub-category tiles",
                            "link":{
                                "linkName":category+" > "+text,
                                "linkType":"sub-category tiles"
                            }
                        });
                    });

                    $('#sorter li').on('click',function(){
                        var sorter = $('#sorter li.selected').text().trim();
                        window.havellsDataLayer.push({
                            "event":"Sort",
                            "Sortyby":{
                                "SortSelected":sorter
                            }
                        });
                    });

                    $('a.am-swatch-link').click(function () {
                        var filterType=$(this).closest('.filter-options-item').find('.filter-options-title').html().trim();
                        var filterSelected=$(this).find('.selected.swatch-option.text').attr('option-label').trim();
                        if(filterSelected!=""){
                            window.havellsDataLayer.push({
                                "event":"Filter",
                                "Filter":{
                                    "FilterSelected": filterType + " > " + filterSelected
                                }
                            });
                        }
                    });

                    $('.toolbar.toolbar-products').on('click','a.action.clear.filter-clear',function (){
                        window.havellsDataLayer.push({
                            "event":"Filter",
                            "Filter":{
                                "FilterSelected":"Clear all > clear all"
                            }
                        });
                    });
                }
                // PDP page on load event
                if ($('body').hasClass("catalog-product-view")){
                    var php_cat_arr = php_cat.split(":");
					var sku =  $('#sku').val();
            
                    let siteSection0 = (typeof php_cat_arr[0]!="undefined")?php_cat_arr[0].toLowerCase():"";
                    let siteSection1 = (typeof php_cat_arr[1]!="undefined")?php_cat_arr[1].toLowerCase():"";
                    let siteSection2 =(typeof php_cat_arr[2]!="undefined")?php_cat_arr[2].toLowerCase():"";
                    let siteSection3 =(typeof php_cat_arr[3]!="undefined")?php_cat_arr[3].toLowerCase():"";
                    let productName = $('.page-title span').html();
                    if(typeof productName=="undefined"){
                        productName = $('.product-subtitle.mb-2.text-muted span').html();
                    }
					
					var dataLayerEvent = {
						"event": "prodView",
						"page": {
							"pageName": php_cat.toLowerCase() + ":" + productName,
							"channel": siteSection0,
							"siteSection1": siteSection0,
							"siteSection2": siteSection1,
							"siteSection3": siteSection2,
							"siteSection4": productName.toLowerCase(),
							"pageType": 'detail page',
							"siteType": siteType.toLowerCase(),
							"brand": brand
						},
						"user": {
							"userID": '',
							"userType": '', // could be employee, customer, business
							"loginStatus": 'anonymous'
						},
						"product": {
							"productID": sku,
							"tags": ""
						}
					};
					setTimeout(function() {
						if ($('#result').text().trim() === 'Product is not available for this pincode') {
							dataLayerEvent.productNotavailable = {
								"pinCode": $('#pincode').val()
							};
						}
						window.havellsDataLayer.push(dataLayerEvent);
					}, 4000);
					
					// PDP share product event
					$('.product-addto-links .dropdown-menu .dropdown-item').on('click', function(event) {
						var clickedLink = $(this).attr('href');
						var clickedText = $(this).text().trim();
						
						window.havellsDataLayer.push({
							"event": "socialMediaShare",
							"product": {
								"productID": $('#sku').val(),
								"tags": ""
							},
							"link": {
								"linkName": clickedText,
								"linkType": "social media share"
							}
						});
					});
					
					// PDP enquire event
					$('.product-info-main .buy-bulk .pdp-inquiry').on('click', function(event) {
						event.preventDefault();
						window.havellsDataLayer.push({
							"event":"makeEnquiry",
							"link":{
								"linkName":"enquire now",
								"linkType":"enquiry"
							}
						});
					});
					
					// Write a review click event when is expand
					$('.write-review .btn').on('click', function(event) {
						var isExpanded = $(this).attr('aria-expanded') === 'true';
						if (isExpanded) {
							window.havellsDataLayer.push({
								"event":"reviewInitate",
									"product":{
										"productID": $('#sku').val(),
										"tags": ""
									},
								"link":{
									"linkName":"write your review",
									"linkType":"review"      
								}

							});
						} 
						//else {
						//	alert('Review form is collapsed');
						//}
					});
					
					// On submit of review event(successful submission)
					$('#review-form .review-form-actions button[type="submit"]').on('click', function(event) {
						setTimeout(() => {
							var isExpanded = $('#review-form').hasClass('show');
							if (isExpanded) {
								if ($(this).is(':disabled')) {
									event.preventDefault();
									window.havellsDataLayer.push({
										"event":"reviewSubmit",
										"product":{
											"productID": $('#sku').val(),
											"tags": ""
										},
										"link":{
											"linkName":"submit review",
											"linkType":"review"
										}
									});
								}
							}
						}, 2000);
					});
					
					// pdp 360 video event
					$('a[href="#productVideo"]').on('click', function() {
						window.havellsDataLayer.push({
							"event":"imageInteraction",
								"product":{
									"productID": $('#sku').val(),
									"tags": ""
								},
							"link":{
								"linkName":"360 view",
								"linkType":"image"      
							}

						});
					});
					
					// pdp cinematography video event
					$('a[href="#productVideo_cinemato"]').on('click', function() {
						window.havellsDataLayer.push({
							"event":"imageInteraction",
								"product":{
									"productID": $('#sku').val(),
									"tags": ""
								},
							"link":{
								"linkName":"cinematography clicks",
								"linkType":"image"      
							}

						});
					});
					
					// pdp download manual
					 $('.pdp-product-mannual').on('click', function() {
						window.havellsDataLayer.push({
							"event":"genericdownload",
								"product":{
									"productID": $('#sku').val(),
									"tags": ""
								},
							"link":{
