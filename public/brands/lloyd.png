                var product = [];
                var cartData = customerData.get('cart');
                console.log(cartData().items);
                let items = cartData().items;
                if(typeof items!="undefined") {
                    items.map((items) => {
                        let temp = {
                            "productID": items.product_sku,
                            "tags": "",
                            "quantity": items.qty
                        }
                        product.push(temp);
                    });
                }
                cartData.subscribe(function (updatedCart){
                    product = [];
                    if (updatedCart.items && updatedCart.items.length > 0) {
                        //console.log('Mini cart items:', updatedCart.items);
                        let items = updatedCart.items;
                        items.map((items)=>{
                            //console.log(items);
                            let temp = {
                                "productID":items.product_sku,
                                "tags":"",
                                "quantity":items.qty
                            }
                            product.push(temp);
                        })
                    } else {
                        //console.log('Mini cart is empty.');
                    }
                });

                if ($('body').hasClass("checkout-index-index")){
                    // var product = [];
                    // var cartData = customerData.get('cart');
                    // var items = cartData().items
                    // console.log(cartData().items);
                    // items.map((items)=>{
                    //     console.log(items);
                    //     let temp = {
                    //         "productID":items.product_sku,
                    //         "tags":"",
                    //         "quantity":items.qty
                    //     }
                    //     product.push(temp);
                    // })
                    console.log(product);
                    window.havellsDataLayer.push({
                        "event": "addressCheckout",
                        "page": {
                            "pageName": "checkout:address",
                            "channel": "checkout",
                            "siteSection1": "checkout",
                            "siteSection2": "address",
                            "siteSection3": "",
                            "pageType": 'checkout',
                            "siteType": siteType.toLowerCase(),
                            "brand": brand
                        },
                        "user": {
                            "userID": '',
                            "userType": '',// could be employee, customer, business
                            "loginStatus": 'anonymous'
                        },
                        "product": product
                    });
                    $('#opc-sidebar').on('click','a.action.viewcart',function() {
                        window.havellsDataLayer.push({
                            "event":"genericClick",
                            "link":{
                                "linkName":"edit",
                                "linkType":"order summary"
                            }
                        });

                    });
					
					// Click event handler for the Apply Discount button in case of valid and invalid
					$('.actions-toolbar').on('click', 'button.action-apply', function (event) {
						event.preventDefault();
						setTimeout(function() {
							var couponCode = $('#discount-code').val().trim();
							window.havellsDataLayer.push({
								"event":"couponApply",
									  
								"product": {
									"productID": product
								},
								"coupon":{
									"couponVal": couponCode
								},  
								"link":{
									"linkName":"coupon applied",
									"linkType":"coupon"
								}
							});
							
							// For valid coupon
							var $successMessage = $('.payment-option-content [data-ui-id="checkout-cart-validationmessages-message-success"]');
							if ($successMessage.length > 0) {
								var couponCode = $('#discount-code').val().trim();
								window.havellsDataLayer.push({
									"event":"couponSuccess",
									"product": {
										"productID": product,
									},
									"coupon":{
										"couponVal": couponCode,
									},  
									"link":{
										"linkName":"coupon applied",
										"linkType":"coupon"
									}
								});
							}

							// For invalid coupon
							var $errorMessage = $('.payment-option-content [data-ui-id="checkout-cart-validationmessages-message-error"]');
							if ($errorMessage.length > 0) {
								var couponCode = $('#discount-code').val().trim();
								var errorMessage = $errorMessage.text().trim();
								window.havellsDataLayer.push({
									"event":"couponFailed",										  
									"product":{
										"productID": product
									},
									"coupon":{
										"couponVal": couponCode
									},  
									"link":{
										"linkName": "coupon failed",
										"linkType": "coupon"
								    },
									"error":{
										"message": errorMessage,
										"code": ""
									}

								});
							}
						}, 2000);
					});
					
					// Remove coupon code
					$('.actions-toolbar').on('click', 'button.action-cancel', function (event) {
						event.preventDefault();
						var couponCode = $('#discount-code').val().trim();
						console.log("coupon remove " + couponCode);
						window.havellsDataLayer.push({
							"event":"couponRemove",
								  
							"product":{
								"productID": product
							},
							"coupon":{
								"couponVal": couponCode
							},  
							"link":{
								"linkName":"coupon removed",
								"linkType": "coupon"
							}

						});
					});					
					
					// Checkout email edit event
					$('#checkout-step-shipping-email').on('click', '.edit-checkout-email', function() {
						window.havellsDataLayer.push({
							"event":"genericClick",
							"link":{
								"linkName":"edit email",
								"linkType":"checkout"      
							}
						});
					});
					
					// Shipping new address event
					$('#shipping .shipping-address-popup').click(function () {
						window.havellsDataLayer.push({
							"event":"genericClick",
								"link":{
								"linkName":"add new address",
								"linkType":"checkout"      
							}
						});
					});
					
					// Billing new address event
					$('#shipping .billing-address-popup').click(function () {
						window.havellsDataLayer.push({
							"event":"genericClick",
								"link":{
								"linkName":"add new address",
								"linkType":"checkout"      
							}
						});
					});
					
                    // Checkout payment
                    $('#shipping-submit-form-buttons-container .primary button').click(function () {
                        window.havellsDataLayer.push({
                            "event":"genericClick",
                            "link":{
                                "linkName":"proceed to payment",
                                "linkType":"checkout"
                            }
                        });

                        var checkExistPayment = setInterval(function () {
                            let url = $(location).attr('href');
                            // console.log("interval run");
                            // console.log(url);
                            if(url.includes("#payment")){
                                clearInterval(checkExistPayment);
                                window.havellsDataLayer.push({
                                    "event": "paymentCheckout",
                                    "page": {
                                        "pageName": "checkout:payment",
                                        "channel": "checkout",
                                        "siteSection1": "checkout",
                                        "siteSection2": "payment",
                                        "siteSection3": "",
                                        "pageType": 'checkout',
                                        "siteType": siteType.toLowerCase(),
                                        "brand": brand
                                    },
                                    "user": {
                                        "userID": '',
                                        "userType": '',// could be employee, customer, business
                                        "loginStatus": 'anonymous'
                                    },
                                    "product": product
                                });


                                $('.payment-group').on('click','button.action.primary.checkout',function() {
                                    window.havellsDataLayer.push({
                                        "event":"genericClick",
                                        "link":{
                                            "linkName":"proceed to confirmation",
                                            "linkType":"checkout"
                                        }
                                    });
                                });

                            }
                        },2000)
                    })

                }

                $('#minicart-content-wrapper').on('click','button#top-cart-btn-checkout',function() {
                    window.havellsDataLayer.push({
                        "event": "checkout",
                        "product": product,
                        "link": {
                            "linkName": "checkout from cart page",
                            "linkType": "cart"
                        }
                    });
                    gtag('event', 'conversion', {'send_to': 'AW-740614232/7rNaCKWMxPUZENjAk-EC'});
                });
                $('#minicart-content-wrapper').on('click','a.action.viewcart',function() {
                    window.havellsDataLayer.push({
                        "event":"genericClick",
                        "link":{
                            "linkName":"view and edit cart",
                            "linkType":"cart"
                        }
                    });
                });
            },2000)

        });
    });
</script>
<input type="hidden" id="siteLang" name="language" value="en_US">
<input type="hidden" id="isLoginStatus" name="loginornot" value="guest">
<input type="hidden" id="moenageCustPhone" name="customerPhone" value="">
<input type="hidden" id="moenageSourceName" name="webistename" value="Havells Website">
<input type="hidden" id="moenageenable" name="moenageenable" value="1">

<script type="text/javascript">
	require([
		'jquery',
		'pdpMoengage',
		'cartPageMoengage',
		'checkoutPageMoengage',
		'Magento_Customer/js/customer-data',
		'jquery/ui'
	], function ($, pdpMoengage, cartPageMoengage, checkoutPageMoengage, customerData) {
		//window.onload = function () {
			$(document).ready(function () {		 
				var utmSource = '';
				var utmMedium = '';
				var utmCampaign = '';
				
				if ($('body').hasClass('cms-home') && $('body').hasClass('cms-index-index') || $('body').hasClass('cms-standard-home')) {
					setTimeout(function() {
						//Onload Home Page Event
						var homePageEvent = {
							loginStatus: 'guest',
							pageName: 'Home',
							pageUrl: window.location.protocol + "//" + window.location.host + window.location.pathname,
							source: 'Havells Website'
						};
						
						utmSource && (homePageEvent.utmSource = utmSource);
						utmMedium && (homePageEvent.utmMedium = utmMedium);
						utmCampaign && (homePageEvent.utmCampaign = utmCampaign);
